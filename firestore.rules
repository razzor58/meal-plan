rules_version = '2';

// Доступ к данным семьи защищён неугадываемым householdId (его знают только
// участники — он в части ссылки после «#»). Любой анонимный пользователь может
// читать/писать конкретную семью, только если знает её id.
service cloud.firestore {
  match /databases/{database}/documents {
    match /households/{hid}/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
